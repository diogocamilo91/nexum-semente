# ============================================================================
# Configuracao unica do kit NEXUM Semente — SEGREDOS + escolhas da pessoa.
#
# >>> Copie este arquivo pra:  ~/.config/semente/config.env   (chmod 600) <<<
#
# Regras:
# - NUNCA versionar, NUNCA subir pro GitHub, NUNCA compartilhar.
# - Fica fora da pasta de conhecimento de proposito (nao vai pro backup).
# - Todos os scripts do kit leem DAQUI. Nada e fixo no codigo.
# - Formato: CHAVE=valor (sem aspas, sem espacos em volta do =). # comenta.
# ============================================================================

# ---------------------------------------------------------------- OBRIGATORIOS

# Token do bot, gerado pelo @BotFather no Telegram (formato 1234567890:AAAA...).
# Como obter: falar com @BotFather -> /newbot -> seguir as perguntas.
TELEGRAM_BOT_TOKEN={TELEGRAM_BOT_TOKEN}

# ID numerico do DONO no Telegram. O bot SO responde a esse ID (seguranca).
# Como obter: o dono manda /start pro @userinfobot e copia o "Id".
TELEGRAM_OWNER_ID={TELEGRAM_OWNER_ID}

# ID do grupo (com Topicos ativados) onde o bot vive. Comeca com -100...
# Como obter: ver o passo "Descobrir o ID do grupo" no LEIA-ME.md.
# Pode ficar vazio durante a instalacao; preencher assim que descobrir.
TELEGRAM_GROUP_ID={TELEGRAM_GROUP_ID}

# ---------------------------------------------------------------- IDENTIDADE

# Nome do assistente (como ele se apresenta) e nome do dono (como ele te chama).
NOME_ASSISTENTE={NOME_ASSISTENTE}
NOME_DONO={NOME_DONO}

# Pasta de conhecimento (onde mora o CLAUDE.md do assistente).
DIR_CONHECIMENTO=~/nexum

# ---------------------------------------------------------------- OPCIONAIS

# Binario do Claude Code (deixe vazio pra auto-detectar pelo PATH).
#CLAUDE_BIN=~/.local/bin/claude

# Quantos Claude podem rodar AO MESMO TEMPO (topicos em paralelo).
# VPS pequena (2 GB RAM): 2. VPS forte (4 GB+): 3.
#MAX_CONCORRENTES=2

# Voz do assistente (Edge-TTS, de graca). Opcoes pt-BR:
#   pt-BR-AntonioNeural  (masculina)  ·  pt-BR-FranciscaNeural (feminina)
# Lista completa: venv/bin/python -m edge_tts --list-voices | grep pt-BR
#TTS_VOZ=pt-BR-AntonioNeural
#TTS_VELOCIDADE=+0%
#TTS_TOM=+0Hz

# Modelo do Whisper (transcricao de audio; baixa sozinho na 1a vez):
#   small (padrao, ~460 MB, ok em 2 GB RAM) · base (mais rapido) · medium/large-v3 (4 GB+ RAM)
#WHISPER_MODELO=small

# Idioma dos audios do dono (pular a deteccao = mais rapido). Vazio = detectar.
#IDIOMA_AUDIO=pt

# Voz Piper de reserva offline (opcional; so usada se o Edge-TTS ficar sem internet).
# Baixar .onnx + .onnx.json de huggingface.co/rhasspy/piper-voices pra piper-voices/.
#PIPER_VOZ=
